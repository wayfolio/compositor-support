{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wayfolio/compositor-support/data.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["generationTimestamp", "version", "globals"],
  "properties": {
    "generationTimestamp": {
      "type": "integer",
      "minimum": 0
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "globals": {
      "type": "array",
      "items": { "$ref": "#/$defs/global" }
    }
  },
  "$defs": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interface", "version"],
      "properties": {
        "interface": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
